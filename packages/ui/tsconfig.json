{
	"extends": "@wanderlust/config/tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "../../",
		"jsx": "react-jsx",
		"outDir": "dist",
		"paths": {
			"@wanderlust/ui/*": [
				"./src/*"
			]
		},
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		]
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
