{
	"name": "@wanderlust/common",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"check-types": "tsc --noEmit",
		"build-types": "tsdown",
		"build-types:watch": "tsdown --watch"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"dependencies": {
		"zod": "catalog:",
		"drizzle-orm": "catalog:",
		"@wanderlust/db": "workspace:*"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"tsdown": "catalog:"
	}
}
