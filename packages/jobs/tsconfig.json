{
	"extends": "../config/tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"],
	"references": [
		{
			"path": "../config"
		},
		{
			"path": "../email"
		},
		{
			"path": "../db"
		},
		{
			"path": "../cache"
		},
		{
			"path": "../common"
		}
	]
}
