{
	"name": "@wanderlust/cache",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"check-types": "tsc --noEmit",
		"build-types": "tsdown",
		"build-types:watch": "tsdown --watch"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"dependencies": {
		"bentocache": "^1.6.1",
		"superjson": "catalog:",
		"inversify": "catalog:",
		"@wanderlust/config": "workspace:*",
		"ioredis": "catalog:"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"tsdown": "catalog:"
	}
}
