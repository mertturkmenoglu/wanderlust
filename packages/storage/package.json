{
	"name": "@wanderlust/storage",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"check-types": "tsc --noEmit",
		"build-types": "tsdown",
		"build-types:watch": "tsdown --watch"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1075.0",
		"@aws-sdk/s3-request-presigner": "^3.1075.0",
		"@wanderlust/config": "workspace:*",
		"flydrive": "^2.1.0",
		"inversify": "catalog:"
	},
	"devDependencies": {
		"typescript": "catalog:"
	}
}
