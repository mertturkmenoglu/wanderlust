{
	"name": "@wanderlust/storage",
	"type": "module",
	"private": true,
	"scripts": {
		"check-types": "tsc --noEmit",
		"build-types": "tsc --build"
	},
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1075.0",
		"@aws-sdk/s3-request-presigner": "^3.1075.0",
		"@wanderlust/config": "workspace:*",
		"flydrive": "^2.1.0",
		"inversify": "catalog:"
	},
	"devDependencies": {
		"typescript": "catalog:"
	}
}
