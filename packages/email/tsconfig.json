{
	"extends": "../config/tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"outDir": "dist",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"paths": {
			"@wanderlust/config": [
				"../config/src/index.ts"
			]
		}
	},
	"references": [
		{
			"path": "../config"
		}
	]
}