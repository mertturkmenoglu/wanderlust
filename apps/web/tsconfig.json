{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"outDir": "dist",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"types": [
			"vite/client"
		],
		"rootDirs": [
			"."
		],
		"paths": {
			"@/*": [
				"./src/*"
			],
		},
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"references": [
		{
			"path": "../../apps/api"
		},
		{
			"path": "../../packages/auth"
		},
		{
			"path": "../../packages/ui"
		},
		{
			"path": "../../packages/config"
		},
		{
			"path": "../../apps/notifications"
		},
		{
			"path": "../../packages/contract"
		},
		{
			"path": "../../apps/chat",
		}
	],
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"*.ts",
		"*.d.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
