{
	"name": "@wanderlust/api",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/src/index.d.mts",
			"default": "./src/index.ts"
		},
		"./*": {
			"types": "./dist/src/*.d.mts",
			"default": "./src/*.ts"
		}
	},
	"module": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"build-types": "tsdown",
		"build-types:watch": "tsdown --watch",
		"check-types": "tsc --noEmit",
		"clean": "bun run src/scripts/clean.ts",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
		"db:generate": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate",
		"db:push": "bunx --bun drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio",
		"dev": "bun run --env-file=../../.env --watch src/index.ts",
		"search": "bun run src/scripts/search/index.ts",
		"start": "NODE_ENV=production bun run dist/index.js",
		"test": "bun test"
	},
	"dependencies": {
		"@hono/otel": "^1.1.2",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.77.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
		"@opentelemetry/instrumentation": "^0.219.0",
		"@opentelemetry/instrumentation-document-load": "^0.64.0",
		"@opentelemetry/resources": "^2.8.0",
		"@opentelemetry/sdk-node": "^0.219.0",
		"@opentelemetry/sdk-trace-node": "^2.8.0",
		"@orpc/client": "catalog:",
		"@orpc/contract": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/otel": "^1.14.6",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@sindresorhus/slugify": "catalog:",
		"@wanderlust/auth": "workspace:*",
		"@wanderlust/cache": "workspace:*",
		"@wanderlust/common": "workspace:*",
		"@wanderlust/config": "workspace:*",
		"@wanderlust/contract": "workspace:*",
		"@wanderlust/db": "workspace:*",
		"@wanderlust/email": "workspace:*",
		"@wanderlust/jobs": "workspace:*",
		"@wanderlust/richtext": "workspace:*",
		"@wanderlust/search": "workspace:*",
		"@wanderlust/storage": "workspace:*",
		"@wanderlust/uid": "workspace:*",
		"date-fns": "catalog:",
		"drizzle-orm": "catalog:",
		"evlog": "catalog:",
		"file-type": "^22.0.1",
		"franc": "^6.2.0",
		"hono": "catalog:",
		"inversify": "catalog:",
		"reflect-metadata": "catalog:",
		"rotating-file-stream": "^3.2.9",
		"winston": "^3.19.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"drizzle-kit": "catalog:",
		"tsdown": "^0.22.0",
		"typescript": "catalog:",
		"unrun": "^0.3.0"
	}
}
