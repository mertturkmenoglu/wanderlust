{
	"name": "@wanderlust/api",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "tsdown",
		"start": "NODE_ENV=production bun run dist/index.js",
		"test": "bun test",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
		"db:push": "bunx --bun drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio",
		"db:generate": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate",
		"fake": "bun run src/scripts/fake/index.ts",
		"search": "bun run src/scripts/search/index.ts"
	},
	"dependencies": {
		"@orpc/client": "catalog:",
		"@orpc/contract": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"bentocache": "^1.5.0",
		"better-auth": "catalog:",
		"bullmq": "^5.65.0",
		"drizzle-orm": "^0.44.7",
		"drizzle-zod": "^0.8.3",
		"file-type": "^21.1.1",
		"flydrive": "^1.3.0",
		"handlebars": "^4.7.8",
		"ioredis": "^5.8.2",
		"nanoid": "^5.1.6",
		"nodemailer": "^7.0.10",
		"pg": "^8.16.3",
		"sharp": "^0.34.5",
		"superjson": "^2.2.5",
		"typesense": "^2.1.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.1.0",
		"@types/bun": "latest",
		"@types/nodemailer": "^7.0.4",
		"@types/pg": "^8.15.6",
		"@wanderlust/config": "workspace:*",
		"drizzle-kit": "^0.31.7",
		"tsdown": "^0.16.6",
		"typescript": "^5.9.3"
	},
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	}
}