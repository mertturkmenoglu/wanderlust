{
	"name": "api",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "tsdown",
		"start": "NODE_ENV=production bun run dist/index.js",
		"test": "bun test",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
		"db:push": "bunx --bun drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio",
		"db:generate": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate"
	},
	"dependencies": {
		"@orpc/client": "^1.11.3",
		"@orpc/contract": "^1.11.3",
		"@orpc/openapi": "^1.11.3",
		"@orpc/server": "^1.11.3",
		"@orpc/zod": "^1.11.3",
		"bentocache": "^1.5.0",
		"better-auth": "^1.4.1",
		"drizzle-orm": "^0.44.7",
		"drizzle-zod": "^0.8.3",
		"file-type": "^21.1.1",
		"flydrive": "^1.3.0",
		"handlebars": "^4.7.8",
		"inngest": "^3.46.0",
		"nanoid": "^5.1.6",
		"nodemailer": "^7.0.10",
		"pg": "^8.16.3",
		"sharp": "^0.34.5",
		"superjson": "^2.2.5",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/nodemailer": "^7.0.4",
		"@types/pg": "^8.15.6",
		"drizzle-kit": "^0.31.7",
		"tsdown": "^0.16.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
