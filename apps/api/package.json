{
	"name": "@wanderlust/api",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "tsdown",
		"start": "NODE_ENV=production bun run dist/index.js",
		"test": "bun test",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
		"db:push": "bunx --bun drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio",
		"db:generate": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate",
		"search": "bun run src/scripts/search/index.ts",
		"clean": "bun run src/scripts/clean.ts"
	},
	"dependencies": {
		"@orpc/client": "catalog:",
		"@orpc/contract": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@react-email/components": "^1.0.12",
		"@wanderlust/common": "workspace:*",
		"@wanderlust/db": "workspace:*",
		"@wanderlust/uid": "workspace:*",
		"bentocache": "^1.6.1",
		"better-auth": "catalog:",
		"bullmq": "^5.76.6",
		"consola": "catalog:",
		"drizzle-orm": "catalog:",
		"file-type": "^22.0.1",
		"flydrive": "^2.1.0",
		"inversify": "catalog:",
		"ioredis": "^5.10.1",
		"nodemailer": "^8.0.7",
		"pg": "catalog:",
		"react": "catalog:",
		"reflect-metadata": "^0.2.2",
		"sharp": "^0.34.5",
		"superjson": "^2.2.5",
		"typesense": "^3.0.6",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "catalog:",
		"@types/react": "catalog:",
		"@wanderlust/config": "workspace:*",
		"@wanderlust/email": "workspace:*",
		"drizzle-kit": "^0.31.10",
		"tsdown": "^0.22.0",
		"typescript": "catalog:"
	},
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	}
}