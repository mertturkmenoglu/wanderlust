{
	"extends": "@wanderlust/config/tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "../../",
		"composite": true,
		"outDir": "dist",
		"paths": {
			"@/*": [
				"./src/*"
			],
			"@wanderlust/email/*": [
				"../../packages/email/emails/*"
			]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"references": [
		{
			"path": "../../packages/email"
		}
	]
}