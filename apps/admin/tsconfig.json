{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"outDir": "dist",

		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"types": ["vite/client"],
		"rootDirs": ["."],
		"paths": {
			"@/*": ["./src/*"],
			"@wanderlust/ui/*": ["../../packages/ui/src/*"],
			"@wanderlust/notifications/*": ["../../apps/notifications/src/*"]
		},
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "*.ts", "*.d.ts"],
	"exclude": ["node_modules", "dist"]
}
